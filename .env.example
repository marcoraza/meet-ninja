# Local runtime
MEET_NINJA_ENV=local
MEET_NINJA_DATA_DIR=./data
MEET_NINJA_DRY_RUN=true

# Google Service Account (Domain-wide Delegation)
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/sa.json
GOOGLE_DELEGATED_USER=contato@agenciaoff.com.br

# Gmail
MEET_NINJA_EMAIL_QUERY=from:meetings-noreply@google.com -label:meet-processed -label:meet-failed
MEET_NINJA_LABEL_PENDING=meet-pending
MEET_NINJA_LABEL_PROCESSED=meet-processed
MEET_NINJA_LABEL_FAILED=meet-failed

# Google Drive (output root)
DRIVE_ROOT_FOLDER_ID=

# Gemini (classifier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7

# GitHub
GITHUB_TOKEN=
GITHUB_REPO=marcoraza/meet-ninja
GITHUB_PROJECTS_YAML_PATH=projects.yaml

# Alerting
ALERT_EMAIL_TO=contato@agenciaoff.com.br
