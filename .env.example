# Local runtime
MEET_NINJA_ENV=local
MEET_NINJA_DATA_DIR=./data
MEET_NINJA_DRY_RUN=true

# E-mail ingestion
MEET_NINJA_EMAIL_PROVIDER=gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
MEET_NINJA_EMAIL_QUERY='from:(meet OR zoom OR calendar) newer_than:30d'

# Vault routing
MEET_NINJA_VAULT_ROOTS_JSON='[]'
MEET_NINJA_DEFAULT_VAULT=

# GitHub operations
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_DEFAULT_REPO=

# Model provider, when needed
OPENAI_API_KEY=
